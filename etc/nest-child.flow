contract.id=kc.nest.child
contract.name=Nest Child
contract.description=Wrapper contract that starts one child kc-flow sub-execution

param.1.id=message
param.1.type=text
param.1.required=0
param.1.default=hello
param.1.label=Message

output.1.id=raw
output.1.type=stream
output.1.label=Raw Output

runtime.command="${KC_FLOW_BIN:-kc-flow}" --run "$KC_FLOW_DIR/nest-child-inner.flow" --fd-out "$KC_FLOW_FD_OUT" --set param.message="$KC_FLOW_PARAM_MESSAGE"
