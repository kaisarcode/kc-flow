flow.id=kc.flow.parallel_prompt
flow.name=Parallel Prompt Fanout
flow.description=One source output fanout to multiple downstream nodes

input.1.id=prompt
input.1.type=text
input.1.required=1
input.1.label=Prompt

node.1.id=rewrite
node.1.contract=kc.example.rewrite

node.2.id=image
node.2.contract=kc.example.image_generate

node.3.id=title
node.3.contract=kc.example.title_generate

node.4.id=tags
node.4.contract=kc.example.tags_generate

link.1.from=input.prompt
link.1.to=node.rewrite.in.prompt

link.2.from=node.rewrite.out.prompt
link.2.to=node.image.in.prompt

link.3.from=node.rewrite.out.prompt
link.3.to=node.title.in.prompt

link.4.from=node.rewrite.out.prompt
link.4.to=node.tags.in.prompt

link.5.from=node.image.out.image
link.5.to=output.image

link.6.from=node.title.out.title
link.6.to=output.title

link.7.from=node.tags.out.tags
link.7.to=output.tags
