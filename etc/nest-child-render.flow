contract.id=kc.nest.child-render
contract.name=Nest Child Render
contract.description=Child sub-execution leaf contract

param.1.id=message
param.1.type=text
param.1.required=0
param.1.default=hello
param.1.label=Message

output.1.id=raw
output.1.type=stream
output.1.label=Raw Output

runtime.command=printf "child:%s" "$KC_FLOW_PARAM_MESSAGE" >"/proc/self/fd/$KC_FLOW_FD_OUT"
