flow.id=kc.nest
flow.name=Nest
flow.description=Minimal parent graph that starts one child kc-flow sub-execution

param.1.id=message
param.1.type=text
param.1.required=0
param.1.default=hello
param.1.label=Message

output.1.id=raw
